# Copy this file to .env (which is ignored) and fill in your real values.
# Never commit your real `.env` to the repository.

# Public (client-visible) variables must start with NEXT_PUBLIC_.
# Only put non-sensitive values here; anything in NEXT_PUBLIC_* is exposed to the browser.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOME_OTHER_PUBLIC_KEY=

# Server-side secrets (do NOT prefix with NEXT_PUBLIC_)
OPENAI_API_KEY=
DATABASE_URL=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
NEXTAUTH_SECRET=
STRIPE_SECRET_KEY=

# Example usage: keep these values in a local .env file and add .env to .gitignore
